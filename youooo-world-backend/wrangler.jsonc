{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "youooo-world-api",
  "main": "worker.js",
  "compatibility_date": "2026-03-23",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "youooo-talent-db",
      "database_id": "da282532-fa22-4443-b323-7da8e8fa5a7a"
    }
  ],
  "triggers": {
    "crons": [
      "0 */6 * * *"
    ]
  }
}
